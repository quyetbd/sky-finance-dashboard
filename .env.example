# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/btm_finance?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Firebase Admin (server-side)
